{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run dev*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run lint*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(node -c *)",
      "Bash(node --check *)",
      "Bash(npx tsc *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./backend/.env)",
      "Read(./frontend/.env)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.*.local)",
      "Read(**/*serviceAccount*.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Bash(cat *.env*)",
      "Bash(cat .env*)",
      "Bash(cat backend/.env)",
      "Bash(cat frontend/.env)"
    ]
  }
}
