{
  "doctype": "DocType",
  "name": "Provisioning Job",
  "module": "Custom",
  "custom": 1,
  "naming_rule": "Expression (old style)",
  "autoname": "format:PRV-{web_account}-{#####}",
  "title_field": "service_name",
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  "fields": [
    { "fieldname": "section_order", "fieldtype": "Section Break", "label": "Order" },
    { "fieldname": "job_key", "fieldtype": "Data", "label": "Job Key", "unique": 1, "read_only": 1, "description": "invoice::service_id — UNIQUE: enforces one job per (invoice, service) so concurrent enqueues can't duplicate." },
    { "fieldname": "web_account", "fieldtype": "Link", "label": "Web Account", "options": "Web Account", "in_list_view": 1, "reqd": 1 },
    { "fieldname": "invoice", "fieldtype": "Link", "label": "Invoice", "options": "Portal Invoice", "in_list_view": 1 },
    { "fieldname": "column_break_order", "fieldtype": "Column Break" },
    { "fieldname": "service_id", "fieldtype": "Data", "label": "Service ID", "reqd": 1, "in_standard_filter": 1 },
    { "fieldname": "service_name", "fieldtype": "Data", "label": "Service Name", "in_list_view": 1 },
    { "fieldname": "category", "fieldtype": "Data", "label": "Category" },

    { "fieldname": "section_routing", "fieldtype": "Section Break", "label": "Routing & Footprint" },
    { "fieldname": "capacity_class", "fieldtype": "Select", "label": "Capacity Class", "options": "\nvolume\npremium\ndedicated" },
    { "fieldname": "lane", "fieldtype": "Select", "label": "Lane", "options": "\ncoolify\nbench\nmanual", "in_list_view": 1, "in_standard_filter": 1 },
    { "fieldname": "target", "fieldtype": "Data", "label": "Target Box", "default": "box-1", "in_list_view": 1, "in_standard_filter": 1, "description": "Which server hosts this tenant (box-1, box-2, …)" },
    { "fieldname": "column_break_routing", "fieldtype": "Column Break" },
    { "fieldname": "ram_mb", "fieldtype": "Int", "label": "RAM (MB)" },
    { "fieldname": "disk_gb", "fieldtype": "Int", "label": "Disk (GB)" },
    { "fieldname": "backup_status", "fieldtype": "Select", "label": "Backup", "options": "pending\nconfigured\nskipped\nfailed", "default": "pending", "description": "Off-site backup state set at create-time" },
    { "fieldname": "repo_url", "fieldtype": "Data", "label": "Repo URL", "description": "BYOA: customer Git repository this job deploys (optional #branch suffix)" },
    { "fieldname": "edge_status", "fieldtype": "Select", "label": "Edge / WAF", "options": "pending\nconfigured\nskipped\nfailed", "default": "pending", "description": "Per-tenant edge/WAF state set at create-time" },

    { "fieldname": "section_status", "fieldtype": "Section Break", "label": "Status" },
    { "fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "queued\nrunning\nactive\nfailed\nneeds_human", "default": "queued", "in_list_view": 1, "in_standard_filter": 1, "reqd": 1 },
    { "fieldname": "attempts", "fieldtype": "Int", "label": "Attempts", "default": "0" },
    { "fieldname": "gated", "fieldtype": "Check", "label": "Capacity Gated", "default": "0", "description": "Set when the RAM gate blocked auto-provisioning (provision KVM #2)" },
    { "fieldname": "external_ref", "fieldtype": "Data", "label": "External Ref", "description": "Coolify app id / bench site name" },
    { "fieldname": "column_break_status", "fieldtype": "Column Break" },
    { "fieldname": "runner_id", "fieldtype": "Data", "label": "Runner ID", "read_only": 1 },
    { "fieldname": "started_at", "fieldtype": "Datetime", "label": "Started At", "read_only": 1 },
    { "fieldname": "next_run_at", "fieldtype": "Datetime", "label": "Next Run At", "description": "Backoff gate — runner skips this job until this time", "read_only": 1 },
    { "fieldname": "access", "fieldtype": "Small Text", "label": "Access (JSON)", "description": "URL, admin user, etc. shown to the customer in the portal" },
    { "fieldname": "error", "fieldtype": "Small Text", "label": "Error" },

    { "fieldname": "section_log", "fieldtype": "Section Break", "label": "Log" },
    { "fieldname": "log", "fieldtype": "Long Text", "label": "Runner Log" }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1 }
  ]
}
