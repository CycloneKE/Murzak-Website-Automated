{
  "doctype": "DocType",
  "name": "Capacity Request",
  "module": "Custom",
  "custom": 1,
  "naming_rule": "Expression (old style)",
  "autoname": "format:CAP-{#####}",
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  "fields": [
    { "fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "pending\nprovisioning\nfulfilled\ncancelled", "default": "pending", "in_list_view": 1, "in_standard_filter": 1, "reqd": 1 },
    { "fieldname": "requested_ram_mb", "fieldtype": "Int", "label": "Requested RAM (MB)", "in_list_view": 1 },
    { "fieldname": "reason", "fieldtype": "Small Text", "label": "Reason" },
    { "fieldname": "column_break_1", "fieldtype": "Column Break" },
    { "fieldname": "autoscale", "fieldtype": "Check", "label": "Autoscale Fired", "default": "0" },
    { "fieldname": "external_ref", "fieldtype": "Data", "label": "External Ref", "description": "Hostinger VPS id when autoscale fired" },
    { "fieldname": "error", "fieldtype": "Small Text", "label": "Error" }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1 }
  ]
}
