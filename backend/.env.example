# ---- Core ----
NODE_ENV=development
PORT=3001
# Generate a long random value, e.g. `openssl rand -hex 32`. REQUIRED in production.
SESSION_SECRET=
# Comma-separated origins allowed to call the API with credentials (production).
# Example: https://murzaktech.com,https://www.murzaktech.com
ALLOWED_ORIGINS=
# Public base URL used to build links in emails (password reset, verification).
# REQUIRED in production: when NODE_ENV=production the server refuses to fall back
# to the (attacker-controlled) Host header, to prevent host-header-poisoned reset
# links. In dev it falls back to the request host. Example: https://murzaktech.com
APP_BASE_URL=

# ---- Frappe / ERPNext backend ----
FRAPPE_BASE_URL=
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# ---- Email (SMTP) ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=
SUPPORT_EMAIL=

# ---- Admin access ----
# Comma-separated admin emails. Also used as the recipients for provisioning
# notifications (see Provisioning below).
ADMIN_EMAILS=

# ---- Provisioning automation ----
# Phase 0: on a paid invoice, record a queued "Provisioning Job" per service and
# email ADMIN_EMAILS so staff can provision from the runbook. Set to "false" to
# pause provisioning entirely without affecting payments/activation.
# (Requires the "Provisioning Job" doctype in Frappe — import
#  backend/data/doctype-provisioning-job.json. Notify-only still works without it.)
PROVISIONING_ENABLED=true

# Phase 1: the runner that actually builds queued jobs (Coolify/bench). OFF by
# default — Phase 0 (notify-only) ships safely without it. Turn on only once a
# lane below is configured.
PROVISIONING_RUNNER_ENABLED=false
# Runner tuning
PROVISIONING_POLL_MS=60000
PROVISIONING_BATCH=5
PROVISIONING_MAX_ATTEMPTS=3
# RAM capacity gate: % of sellable RAM that may be auto-committed before a
# premium/ERP job is escalated to a human (the "provision KVM #2" signal).
PROVISIONING_RAM_THRESHOLD_PCT=85

# Per-order capacity caps (server-side guard mirroring the configurator): a single
# self-serve order can't exceed what one shared tenant may use — beyond this it's
# routed to a dedicated/Enterprise quote. Keep in sync with the frontend caps.
SELF_SERVE_ORDER_RAM_CAP_MB=6144
SELF_SERVE_ORDER_DISK_CAP_GB=80

# Lane A — Coolify (web/app/static/db). Runner escalates to a human if unset.
COOLIFY_BASE_URL=
COOLIFY_TOKEN=
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENV_NAME=production

# Lane B — Frappe bench (ERP/POS/CRM). Absolute path to an idempotent provisioning
# script/playbook wrapper; it receives JOB_* env vars and must print a final JSON
# line {"site":"…","url":"…","admin":"…"} on success.
BENCH_PROVISION_CMD=
BENCH_PROVISION_TIMEOUT_MS=600000

# ---- Provisioning Phase 2 (scale-out + backups) ----
# How many jobs the runner builds in parallel per pass.
PROVISIONING_CONCURRENCY=2
# Extra hosting boxes beyond box-1 (the original KVM 4). JSON array; each box may
# carry its own Coolify creds and/or bench command. Premium tenants are placed on
# the first box with RAM headroom. Example:
# PROVISIONING_TARGETS=[{"id":"box-2","sellableRamMb":12800,"status":"active","coolify":{"baseUrl":"https://cool2.example","token":"…","projectUuid":"…","serverUuid":"…"},"benchCmd":"/opt/murzak/provision-box2.sh"}]
PROVISIONING_TARGETS=[]

# When ALL boxes are at the RAM threshold, a Capacity Request is recorded and
# staff are emailed. Set true (and provide a Hostinger token) to ALSO auto-create
# the next VPS via the Hostinger API. Off by default — creating a paid server is
# an explicit opt-in.
PROVISIONING_AUTOSCALE=false
HOSTINGER_API_TOKEN=
HOSTINGER_API_BASE=https://api.hostinger.com
HOSTINGER_VPS_PLAN=
HOSTINGER_DC_ID=
HOSTINGER_TEMPLATE_ID=

# Off-site backups wired at tenant create-time. Backups MUST NOT sit on the same
# NVMe as the data. BACKUP_CONFIG_CMD is an idempotent script that receives
# TENANT_* env vars and sets up the off-site job. Unset => backups recorded as
# "skipped" on the job (visible, not silently missing).
BACKUP_PROVIDER=
BACKUP_CONFIG_CMD=
BACKUP_CONFIG_TIMEOUT_MS=120000

# Per-tenant edge / WAF wired at create-time (Cloudflare etc). EDGE_CONFIG_CMD is
# an idempotent script receiving TENANT_* env vars (create DNS + WAF policy +
# proxy). Unset => edge recorded as "skipped" on the job.
EDGE_PROVIDER=
EDGE_CONFIG_CMD=
EDGE_CONFIG_TIMEOUT_MS=120000

# Cap on premium (ERP/POS/CRM) tenants per box, to bound noisy-neighbour load on
# the shared bench/MariaDB beyond the raw RAM gate. Empty = RAM gate only.
# (Extra boxes carry their own "maxPremiumTenants" inside PROVISIONING_TARGETS.)
PROVISIONING_BOX1_MAX_PREMIUM=

# ---- Provisioning dispatch (queue) ----
# "poll" (default): in-process interval runner. "bullmq": Redis-backed dispatch
# with atomic per-job locking + low-latency pickup (recommended once you run more
# than one backend instance). The Frappe doctype stays the source of truth either
# way.
PROVISIONING_QUEUE=poll
# DEDICATED, persistent Redis for the job queue. Do NOT reuse the session cache
# Redis: if that cache evicts keys, queued provisioning jobs are silently lost.
# This Redis should have maxmemory-policy=noeviction and AOF/RDB persistence on.
PROVISIONING_REDIS_URL=
# How often (ms) to re-inject queued doctype rows missing from Redis (safety net
# for Redis restarts / lost events). Min 30000.
PROVISIONING_RECONCILE_MS=300000

# ---- M-Pesa (Safaricom Daraja) ----
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public URL Safaricom posts payment results to. Append the secret token below as a
# query param, e.g. https://murzaktech.com/api/billing/mpesa/callback?token=YOUR_SECRET
MPESA_CALLBACK_URL=
# Unguessable token that must be present on incoming callbacks (defends the public
# callback endpoint since Safaricom does not sign requests). Generate with `openssl rand -hex 24`.
MPESA_CALLBACK_SECRET=

# ---- Free-trial verification ----
# Free / KES-0 plans (e.g. the Test Drive trial) require a real card OR M-Pesa STK
# transaction of this nominal amount before services activate — there is no free,
# unverified activation. Default 1 (KES). M-Pesa has no minimum; live card
# processors often reject < ~USD 0.50, so for card-verified trials in production
# set this so its USD conversion clears that floor (e.g. 70+).
TRIAL_VERIFY_AMOUNT_KES=1
# Catalog service id seeded as the trial sandbox when a trial account is created.
TRIAL_SANDBOX_SERVICE_ID=test-erpnext-demo
# 36h trial expiry sweep: set to "false" to disable; interval in ms (default 15m).
TRIAL_EXPIRY_ENABLED=true
TRIAL_EXPIRY_INTERVAL_MS=900000
#
# FRAPPE SCHEMA the trial flow assumes (validate on the live instance):
#  - Test Plan Invoice has fields: trial_hours, trial_start (Datetime), trial_end
#    (Datetime), web_account (Link), web_account_email, status accepting
#    "Trial Pending"/"Active"/"Expired".
#  - Portal Invoice `type` accepts "Trial Verification".

# ---- PayPal ----
# Webhook (REQUIRED for reliable payment finality): in the PayPal Developer
# dashboard create a webhook pointing at  https://<your-domain>/api/paypal/webhook
# subscribed to: PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.REFUNDED,
# PAYMENT.CAPTURE.REVERSED, PAYMENT.CAPTURE.DENIED. Paste its ID into the
# matching *_WEBHOOK_ID below. Without it, payments rely solely on the browser
# round-trip and refunds/chargebacks are not reconciled.
# For full capture audit, import the Portal Invoice custom fields once:
#   bench --site <site> import-doc backend/data/custom-fields-portal-invoice.json
# (payment_gateway / paypal_order_id / paypal_capture_id — persisted best-effort).
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=USD
KES_TO_USD_RATE=
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_SANDBOX_WEBHOOK_ID=
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=
PAYPAL_LIVE_WEBHOOK_ID=
