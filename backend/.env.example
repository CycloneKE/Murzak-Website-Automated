# ---- Core ----
NODE_ENV=development
PORT=3001
# Bypass Frappe auth and auto-login as a dev user (for frontend UI work without a backend DB)
DEV_AUTO_LOGIN=false
# Generate a long random value, e.g. `openssl rand -hex 32`. REQUIRED in production.
SESSION_SECRET=
# Comma-separated EXTRA origins allowed to call the API with credentials.
# Same-origin requests (the SPA served by this app) are always allowed —
# browsers send an Origin header even on same-origin POSTs, so the check
# compares against the request's own scheme+host. Only list origins here for
# split deployments (frontend on a different domain) or local dev tools.
# Example: https://www.murzaktech.com
ALLOWED_ORIGINS=
# Public base URL used to build links in emails (password reset, verification).
# REQUIRED in production: when NODE_ENV=production the server refuses to fall back
# to the (attacker-controlled) Host header, to prevent host-header-poisoned reset
# links. In dev it falls back to the request host. Example: https://murzaktech.com
APP_BASE_URL=

# Session-cache Redis (express-session store + per-account login throttling).
# Unset => in-memory MemoryStore: sessions drop on every restart and DO NOT work
# across multiple backend instances. STRONGLY recommended in production (the boot
# logs a warning when running without it). Distinct from PROVISIONING_REDIS_URL
# below — this cache MAY evict keys; the provisioning queue Redis MUST NOT.
# Example: redis://:password@127.0.0.1:6379/0
REDIS_URL=

# ---- Frappe / ERPNext backend ----
FRAPPE_BASE_URL=
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
# Web Account doctype + child-table field names the provisioning runner uses to
# flip a managed service row to "Active". Defaults below match server.js — only
# set these if your Frappe schema renames them.
# WEB_ACCOUNT_DOCTYPE=Web Account
# WEB_ACCOUNT_SERVICES_FIELD=selected_services
# CHILD_SERVICE_ID_FIELD=service_id
# CHILD_STATUS_FIELD=status

# ---- Firebase (server-side admin: verifies Google sign-in ID tokens) ----
# The service-account JSON, as either raw JSON or base64-encoded JSON (handy for
# env stores that dislike newlines/quotes). Unset => Firebase admin disabled and
# Google sign-in verification no-ops. This is a SECRET — keep it out of git and
# out of the client bundle. (The frontend's PUBLIC Firebase web config lives in
# frontend/.env as VITE_FIREBASE_* and is unrelated to this.)
FIREBASE_SERVICE_ACCOUNT=

# ---- Email (SMTP) ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=
SUPPORT_EMAIL=

# ---- Admin access ----
# Comma-separated admin emails. Also used as the recipients for provisioning
# notifications (see Provisioning below).
ADMIN_EMAILS=

# ---- Provisioning automation ----
# Phase 0: on a paid invoice, record a queued "Provisioning Job" per service and
# email ADMIN_EMAILS so staff can provision from the runbook. Set to "false" to
# pause provisioning entirely without affecting payments/activation.
# (Requires the "Provisioning Job" doctype in Frappe — import
#  backend/data/doctype-provisioning-job.json. Notify-only still works without it.)
PROVISIONING_ENABLED=true

# Phase 1: the runner that actually builds queued jobs (Coolify/bench). OFF by
# default — Phase 0 (notify-only) ships safely without it. Turn on only once a
# lane below is configured.
PROVISIONING_RUNNER_ENABLED=false
# Mock provisioning: when true, both Coolify and Bench lanes are replaced with a
# simulated adapter that returns success after a short delay. The full runner
# state machine (claim → build → active, backups, edge, capacity gate) runs
# end-to-end against Frappe without touching real infrastructure. Disable in
# production. Optional: MOCK_PROVISION_DELAY_MS (default 1500),
# MOCK_PROVISION_FAIL_RATE (0-1, default 0 — fraction of builds that fail to
# exercise retry/escalation logic).
MOCK_PROVISIONING=false
# Runner tuning
PROVISIONING_POLL_MS=60000
PROVISIONING_BATCH=5
PROVISIONING_MAX_ATTEMPTS=3
# RAM capacity gate: % of sellable RAM that may be auto-committed before a
# premium/ERP job is escalated to a human (the "provision KVM #2" signal).
PROVISIONING_RAM_THRESHOLD_PCT=85

# Per-order capacity caps (server-side guard mirroring the configurator): a single
# self-serve order can't exceed what one shared tenant may use — beyond this it's
# routed to a dedicated/Enterprise quote. Keep in sync with the frontend caps.
SELF_SERVE_ORDER_RAM_CAP_MB=6144
SELF_SERVE_ORDER_DISK_CAP_GB=80

# Lane A — Coolify (web/app/static/db). Runner escalates to a human if unset.
COOLIFY_BASE_URL=
COOLIFY_TOKEN=
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENV_NAME=production
# Per-request timeout (ms) for Coolify API calls. Default 30000.
# COOLIFY_TIMEOUT_MS=30000
# The box's own public IP — used ONLY to verify a customer's domain actually
# points here before we hand it to Coolify (POST /api/portal/services/:id/domain).
# We never touch DNS ourselves. Unset => domain self-service is disabled (503).
COOLIFY_SERVER_IP=
# Per-container PID limit applied at provision time (fork-bomb bound on the
# shared box). Default 512 — generous for git/npm/composer, tight enough to
# stop runaway process spawning. CPU/memory/disk limits are derived
# automatically from each service's footprint; this is the one manual knob.
# COOLIFY_PIDS_LIMIT=512
# BYOA customer hostnames: every deployed app gets {slug}.{APP_DOMAIN_BASE}
# (e.g. my-shop.apps.murzaktech.tech). Requires a ONE-TIME wildcard DNS record
# (*.apps.murzaktech.tech A -> this box's IP) created manually at the DNS host;
# the deploy path never calls a DNS API. Unset => apps still deploy, the portal
# shows "URL pending" (never the Coolify admin panel), and the URL falls back
# to Coolify's own auto-generated hostname when it reports one.
APP_DOMAIN_BASE=
# BYOA build wait: the runner polls the Coolify deployment until it FINISHES
# (a job is never "active" on resource creation alone). Poll interval + total
# budget per attempt; a timed-out build resumes on the next runner pass.
# COOLIFY_BUILD_POLL_MS=10000
# COOLIFY_BUILD_TIMEOUT_MS=600000
# Verify the live Coolify API's field names/status vocabulary from the VPS:
#   node backend/scripts/coolify-smoke.js --create

# ---- Developer-access terminal broker (Phase 5) ----
# Master gate for the browser terminal feature. Default false — the whole
# feature (backend mint route + broker) is inert until this is true AND the
# security prerequisites are met (see how-does-one-create-deep-kazoo.md §P5.0).
TERMINAL_ENABLED=false
# Internal URL of the terminal broker (see broker/ + docker-compose.broker.yml).
# The broker is NON-internet-facing; this is a private-network address.
# BROKER_URL=http://broker:4600
# Shared secret for the backend→broker internal calls, and the HMAC key the
# broker signs connect-tokens with. BROKER_SIGNING_KEY MUST differ from
# SESSION_SECRET (a backend compromise must not be able to forge broker tokens).
# Generate each with `openssl rand -hex 32`.
# BROKER_API_KEY=
# BROKER_SIGNING_KEY=

# ---- Developer-access terminal: recordings + retention (Phase 5.4) ----
# Off-box object storage for session recordings (S3-compatible: AWS S3,
# Backblaze B2, DO Spaces). Recordings hold customer secrets — never stored
# in Frappe itself, only a compact audit line. See services/terminal/s3Client.js.
# TERMINAL_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# TERMINAL_S3_BUCKET=
# TERMINAL_S3_REGION=us-west-002
# TERMINAL_S3_ACCESS_KEY_ID=
# TERMINAL_S3_SECRET_ACCESS_KEY=
# Narrower than ADMIN_EMAILS — only these emails may view recording CONTENT
# (not just metadata). Every access, granted or denied, is logged.
# TERMINAL_RECORDING_ACCESS_EMAILS=
# Retention windows in days (defaults: routine=30, flagged=90; legal_hold is
# always indefinite and set manually, never via env).
# TERMINAL_RETENTION_DAYS_ROUTINE=30
# TERMINAL_RETENTION_DAYS_FLAGGED=90
# Purge sweep cadence — off unless TERMINAL_ENABLED=true.
# TERMINAL_RETENTION_SWEEP_INTERVAL_MS=3600000

# Lane B — Frappe bench (ERP/POS/CRM). Absolute path to an idempotent provisioning
# script/playbook wrapper; it receives JOB_* env vars and must print a final JSON
# line {"site":"…","url":"…","admin":"…"} on success.
BENCH_PROVISION_CMD=
BENCH_PROVISION_TIMEOUT_MS=600000

# ---- Provisioning Phase 2 (scale-out + backups) ----
# How many jobs the runner builds in parallel per pass.
PROVISIONING_CONCURRENCY=2
# Extra hosting boxes beyond box-1 (the original KVM 4). JSON array; each box may
# carry its own Coolify creds and/or bench command. Premium tenants are placed on
# the first box with RAM headroom. Example:
# PROVISIONING_TARGETS=[{"id":"box-2","sellableRamMb":12800,"status":"active","coolify":{"baseUrl":"https://cool2.example","token":"…","projectUuid":"…","serverUuid":"…"},"benchCmd":"/opt/murzak/provision-box2.sh"}]
PROVISIONING_TARGETS=[]

# When ALL boxes are at the RAM threshold, a Capacity Request is recorded and
# staff are emailed. Set true (and provide a Hostinger token) to ALSO auto-create
# the next VPS via the Hostinger API. Off by default — creating a paid server is
# an explicit opt-in.
PROVISIONING_AUTOSCALE=false
HOSTINGER_API_TOKEN=
HOSTINGER_API_BASE=https://api.hostinger.com
# Per-request timeout (ms) for Hostinger API calls. Default 30000.
# HOSTINGER_TIMEOUT_MS=30000
HOSTINGER_VPS_PLAN=
HOSTINGER_DC_ID=
HOSTINGER_TEMPLATE_ID=

# Admin "Infrastructure Access" quick-links (Portal > Admin). Redirects only —
# we don't run our own shell broker onto the shared box. HOSTINGER_HPANEL_URL
# should point at the specific VPS's hPanel page (has a built-in browser SSH
# terminal); FRAPPE_HELPDESK_URL overrides the default `${FRAPPE_BASE_URL}/helpdesk`
# if the Helpdesk app isn't installed or lives at a different path.
HOSTINGER_HPANEL_URL=
FRAPPE_HELPDESK_URL=

# Off-site backups wired at tenant create-time. Backups MUST NOT sit on the same
# NVMe as the data. BACKUP_CONFIG_CMD is an idempotent script that receives
# TENANT_* env vars and sets up the off-site job. Unset => backups recorded as
# "skipped" on the job (visible, not silently missing).
BACKUP_PROVIDER=
BACKUP_CONFIG_CMD=
BACKUP_CONFIG_TIMEOUT_MS=120000

# Per-tenant edge / WAF wired at create-time (Cloudflare etc). EDGE_CONFIG_CMD is
# an idempotent script receiving TENANT_* env vars (create DNS + WAF policy +
# proxy). Unset => edge recorded as "skipped" on the job.
EDGE_PROVIDER=
EDGE_CONFIG_CMD=
EDGE_CONFIG_TIMEOUT_MS=120000

# Cap on premium (ERP/POS/CRM) tenants per box, to bound noisy-neighbour load on
# the shared bench/MariaDB beyond the raw RAM gate. Empty = RAM gate only.
# (Extra boxes carry their own "maxPremiumTenants" inside PROVISIONING_TARGETS.)
PROVISIONING_BOX1_MAX_PREMIUM=

# ---- Provisioning dispatch (queue) ----
# "poll" (default): in-process interval runner. "bullmq": Redis-backed dispatch
# with atomic per-job locking + low-latency pickup (recommended once you run more
# than one backend instance). The Frappe doctype stays the source of truth either
# way.
PROVISIONING_QUEUE=poll
# DEDICATED, persistent Redis for the job queue. Do NOT reuse the session cache
# Redis: if that cache evicts keys, queued provisioning jobs are silently lost.
# This Redis should have maxmemory-policy=noeviction and AOF/RDB persistence on.
PROVISIONING_REDIS_URL=
# How often (ms) to re-inject queued doctype rows missing from Redis (safety net
# for Redis restarts / lost events). Min 30000.
PROVISIONING_RECONCILE_MS=300000

# ---- M-Pesa (Safaricom Daraja) ----
# The callback looks up the invoice by mpesa_checkout_request_id — this field
# (plus mpesa_receipt_number) must exist on Portal Invoice or the callback can
# never find the invoice to activate it. Import once:
#   bench --site <site> import-doc backend/data/custom-fields-portal-invoice-mpesa.json
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public URL Safaricom posts payment results to. Append the secret token below as a
# query param, e.g. https://murzaktech.com/api/billing/mpesa/callback?token=YOUR_SECRET
MPESA_CALLBACK_URL=
# Unguessable token that must be present on incoming callbacks (defends the public
# callback endpoint since Safaricom does not sign requests). Generate with `openssl rand -hex 24`.
MPESA_CALLBACK_SECRET=

# ---- Free-trial verification ----
# Free / KES-0 plans (e.g. the Test Drive trial) require a real card OR M-Pesa STK
# transaction of this nominal amount before services activate — there is no free,
# unverified activation. Default 1 (KES). M-Pesa has no minimum; live card
# processors often reject < ~USD 0.50, so for card-verified trials in production
# set this so its USD conversion clears that floor (e.g. 70+).
TRIAL_VERIFY_AMOUNT_KES=1
# Catalog service id seeded as the trial sandbox when a trial account is created.
TRIAL_SANDBOX_SERVICE_ID=test-erpnext-demo
# 36h trial expiry sweep: set to "false" to disable; interval in ms (default 15m).
TRIAL_EXPIRY_ENABLED=true
TRIAL_EXPIRY_INTERVAL_MS=900000
#
# FRAPPE SCHEMA the trial flow assumes (validate on the live instance):
#  - Test Plan Invoice has fields: trial_hours, trial_start (Datetime), trial_end
#    (Datetime), web_account (Link), web_account_email, status accepting
#    "Trial Pending"/"Active"/"Expired".
#  - Portal Invoice `type` accepts "Trial Verification".

# ---- Recurring billing (renewal sweep) ----
# Generates the month-2+ subscription invoice once an account's latest PAID
# subscription invoice is older than the cycle, logs a portal alert and emails
# the customer. Idempotent (never stacks a second open subscription invoice).
RENEWAL_ENABLED=true
RENEWAL_CYCLE_DAYS=30
# Days an unpaid renewal may sit before enforcement.
RENEWAL_GRACE_DAYS=7
# OPT-IN: when true, accounts past grace get services suspended + account_status
# "Suspended" (restored by paying — activation flips them back). Leave false
# until the renewal email flow is verified in production.
RENEWAL_SUSPEND_ENABLED=false
# Sweep interval in ms (min 15m). Default 6h.
RENEWAL_INTERVAL_MS=21600000

# ---- PayPal ----
# Webhook (REQUIRED for reliable payment finality): in the PayPal Developer
# dashboard create a webhook pointing at  https://<your-domain>/api/paypal/webhook
# subscribed to: PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.REFUNDED,
# PAYMENT.CAPTURE.REVERSED, PAYMENT.CAPTURE.DENIED. Paste its ID into the
# matching *_WEBHOOK_ID below. Without it, payments rely solely on the browser
# round-trip and refunds/chargebacks are not reconciled.
# For full capture audit, import the Portal Invoice custom fields once:
#   bench --site <site> import-doc backend/data/custom-fields-portal-invoice.json
# (payment_gateway / paypal_order_id / paypal_capture_id — persisted best-effort).
PAYPAL_ENV=sandbox
KES_TO_USD_RATE=
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_SANDBOX_WEBHOOK_ID=
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=
PAYPAL_LIVE_WEBHOOK_ID=
