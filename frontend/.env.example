# Firebase web config (PUBLIC — safe to ship in the client bundle).
# Copy this file to `.env` (or `.env.local`) and fill in the values from your
# Firebase project: Project settings → General → Your apps → SDK setup & config.
#
# Auth (Google sign-in) needs: API_KEY, AUTH_DOMAIN, PROJECT_ID, APP_ID.
# Analytics (GA4 page_view) additionally needs: MEASUREMENT_ID.
# Leave all blank to run with Firebase disabled (the app works unchanged;
# the "Continue with Google" button is hidden and page_view logging no-ops).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
